@page "/transactions"
@page "/transactions/{CanDeleteAll:bool}"
@page "/transactions/{ChartPeriod}/{Category:int}/{CanGoBack:bool}"

@using Microsoft.FluentUI.AspNetCore.Components

<div style="width: 100%; display: flex; flex-direction: column; flex: 1; min-height: 0;">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="20" Style="margin: 10px 0; width: 100%; flex-shrink: 0;">
        <FluentLabel Typo="Typography.H3"> Transactions</FluentLabel>

        <FluentSelect TOption="string" @bind-Value="@selectedPeriod" Label="Select period" SelectedOptionChanged="OnPeriodChanged">
            <FluentOption Value="m1">This month</FluentOption>
            <FluentOption Value="m2">Last month</FluentOption>
            <FluentOption Value="m1+2">This + Last month</FluentOption>
            <FluentOption Value="m1+3">This + 2 last months</FluentOption>
            <FluentOption Value="w1">Last 7 days</FluentOption>
            <FluentOption Value="w2">Last 14 days</FluentOption>
            <FluentOption Value="w3">Last 31 days</FluentOption>
            <FluentOption Value="12">Last 12 months</FluentOption>
            <FluentOption Value="y1">This year</FluentOption>
            <FluentOption Value="y2">Last year</FluentOption>
            <FluentOption Value="y3">Two years ago</FluentOption>
            <FluentOption Value="y12">This + Last year</FluentOption>
            <FluentOption Value="a">All</FluentOption>
        </FluentSelect>

        @if (CanDeleteAll)
        {
            <FluentButton Appearance="Appearance.Stealth" OnClick="DeleteAll"> Delete All </FluentButton>
        }
        @if (CanGoBack)
        {
            <FluentButton IconStart="@(new Icons.Filled.Size28.ArrowCircleLeft())" OnClick="GoBack"> Back </FluentButton>
        }
    </FluentStack>

    <div style="flex: 1; min-height: 0; display: flex;">
        <TransactionsList ChartPeriod="@selectedPeriod" Category="@Category"/>
    </div>
</div>